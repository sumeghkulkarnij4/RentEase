# =============================================
# RentEase Server — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to Git.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB Atlas ---
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rentease?retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_here

# --- Cloudinary (Image Storage) ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Razorpay (Payments) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# --- CORS (set to your Vercel frontend URL in production) ---
# FRONTEND_URL=https://rentease.vercel.app
